# API settings
DATABASE_URL=postgresql://reframe:reframe@localhost:5432/reframe
MEDIA_ROOT=./media
BROKER_URL=redis://localhost:6379/0
RESULT_BACKEND=${BROKER_URL}
REFRAME_OFFLINE_MODE=true
REFRAME_MAX_UPLOAD_BYTES=1073741824
REFRAME_CLEANUP_TTL_HOURS=24
REFRAME_CLEANUP_INTERVAL_SECONDS=3600
REFRAME_JOB_RETRY_MAX_ATTEMPTS=2
REFRAME_JOB_RETRY_BASE_DELAY_SECONDS=1
REFRAME_HOSTED_MODE=false
REFRAME_ENABLE_OAUTH=false
REFRAME_ENABLE_BILLING=false
REFRAME_JWT_SECRET=change-me-access-secret
REFRAME_JWT_REFRESH_SECRET=change-me-refresh-secret
REFRAME_JWT_ACCESS_TTL_MINUTES=15
REFRAME_JWT_REFRESH_TTL_DAYS=30
REFRAME_APP_BASE_URL=http://localhost:5173
REFRAME_API_BASE_URL=http://localhost:8000
REFRAME_OAUTH_STATE_SECRET=change-me-oauth-state-secret
REFRAME_OAUTH_GOOGLE_CLIENT_ID=
REFRAME_OAUTH_GOOGLE_CLIENT_SECRET=
REFRAME_OAUTH_GITHUB_CLIENT_ID=
REFRAME_OAUTH_GITHUB_CLIENT_SECRET=
REFRAME_STRIPE_SECRET_KEY=
REFRAME_STRIPE_WEBHOOK_SECRET=
REFRAME_STRIPE_PRICE_PRO=
REFRAME_STRIPE_PRICE_ENTERPRISE=
HF_TOKEN=
OPENAI_API_KEY=your-openai-key
GROQ_API_KEY=your-groq-key
TRANSLATOR_PROVIDER=
TRANSLATOR_API_KEY=

# Optional remote storage (S3/R2)
REFRAME_STORAGE_BACKEND=local
REFRAME_S3_BUCKET=
REFRAME_S3_PREFIX=
REFRAME_S3_REGION=
REFRAME_S3_ENDPOINT_URL=
REFRAME_S3_PUBLIC_BASE_URL=
REFRAME_S3_PRESIGN_EXPIRES_SECONDS=604800
REFRAME_S3_ACCESS_KEY_ID=
REFRAME_S3_SECRET_ACCESS_KEY=
REFRAME_S3_SESSION_TOKEN=

# Web app settings
VITE_API_BASE_URL=http://localhost:8000/api/v1
