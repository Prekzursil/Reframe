# Node / Electron
node_modules/
app/dist/
app/out/
app/.vite/
*.log

# Playwright run artifacts (reports + per-test traces/screenshots) — regenerable,
# never commit. Screenshot BASELINES under e2e/**/-snapshots/ ARE tracked.
app/playwright-report/
app/test-results/
# Ad-hoc end-to-end scratch outputs (probe scripts + runner datadirs/library.db
# written under e2e_artifacts/ during manual E2E drives) — regenerable, never commit.
e2e_artifacts/

# Python
__pycache__/
*.pyc
.venv/
sidecar/.venv/
.pytest_cache/
*.egg-info/

# Coverage artifacts (never commit — regenerated by the test gate)
.coverage
.coverage.*
coverage.xml
htmlcov/
coverage/
.ruff_cache/

# App data / models / artifacts (never commit large binaries or models)
models/
# ...but the Python SOURCE package media_studio/models/ is code, NOT a model
# artifact — keep it tracked (artifact file types below are ignored regardless):
!sidecar/media_studio/models/
!sidecar/media_studio/models/*.py
*.gguf
*.pt
*.onnx
*.safetensors
out/
clips/
*.mp4
*.mkv
*.mov
*.webm

# but keep the spike's reference inputs
!spike/talk.en.vtt

# Reframe ML eval golden set (WU R0) — PRIVATE / third-party, NEVER committed.
# The OpusClip-derived golden reference (the razvan_gandu RO talk-show + its 41
# derived clips) is sourced via the REFRAME_GOLDEN_DIR env var (an EXTERNAL path,
# e.g. ~/Downloads/razvan_gandu); these patterns defend against an accidental
# repo-relative copy. The 100% pure-coverage tier never needs these bytes.
razvan_gandu/
**/razvan_gandu/
testdata/razvan_gandu/

# Local agent / orchestration state (never commit — machine-local recovery)
.beads/
.claude/

# Mutation-testing artifacts (regenerated by the nightly mutation.yml — never commit)
.mutmut-cache
mutants/
sidecar/mutants/
app/.stryker-tmp/
app/reports/mutation/
stryker.log

# OS
.DS_Store
Thumbs.db

# secrets (cloud key lives in app settings/OS, never the repo)
secrets.local.*
*.secret

# build artifacts (installer + unpacked) — never commit
dist/
# Built installers (NSIS .exe + portable .zip) — large binaries; attach to
# GitHub Releases, never commit to the repo.
installers/

# Regenerable build binaries (staged by build/python-embed-setup.ps1 -WithFfmpeg)
build/ffmpeg/
# The dedicated py3.14 embeddable for the isolated chatterbox env is large and
# regenerable by the same prep script — never commit it (mirrors build/ffmpeg/).
# NOTE: build/python-embed/ (py3.12) IS tracked historically; this only covers 3.14.
build/python-embed-314/
# Stray duplicate icon dir — the REAL app icons live in build/icons/ (plural,
# committed by WU A2). build/icon/ (singular) is a regenerable leftover dup an
# icon step emits; never commit it (the tracked build/icons/ is the source of truth).
build/icon/

# Runtime data root (models/exports/envs — relocatable via MEDIA_STUDIO_CONFIG_DIR)
/data/
