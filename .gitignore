apps/desktop/src-tauri/keys/tauri.key

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/

# Node / frontend
node_modules/
dist/
*.tsbuildinfo

# IDE / tooling
.DS_Store
.vscode/
.idea/
.tools/

# Logs & coverage
*.log
coverage/
.coverage

# Local dev SQLite DB
reframe*.db

# Local sample media
samples/

_sonar-issues.json
_sonar-issues-raw.json

