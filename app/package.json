{
  "name": "media-studio",
  "version": "1.0.0",
  "description": "Local personal video-manager desktop app (Electron + Python sidecar)",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "author": "media-studio",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build && npm run build:remotion",
    "build:remotion": "npm --prefix render-cli run bundle",
    "render-cli:install": "npm --prefix render-cli install",
    "render-cli:bundle": "npm --prefix render-cli run bundle",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:dom": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:visual": "playwright test --config playwright.visual.config.ts",
    "test:e2e:visual:update": "playwright test --config playwright.visual.config.ts --update-snapshots"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.0",
    "axe-core": "^4.12.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.6",
    "electron": "^39.0.0",
    "electron-builder": "^26.15.3",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "^3.1.0",
    "fast-check": "^3.23.2",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
